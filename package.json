{
  "name": "@redwoodjs/sourdough",
  "version": "0.1.0",
  "private": true,
  "description": "Portable Cloudflare-compatible bindings for Node.js and Nub.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./durable-object": {
      "types": "./dist/bindings/durable-object/src/index.d.ts",
      "import": "./dist/bindings/durable-object/src/index.js"
    },
    "./durable-object/node": {
      "types": "./dist/bindings/durable-object/src/providers/node/index.d.ts",
      "import": "./dist/bindings/durable-object/src/providers/node/index.js"
    },
    "./r2": {
      "types": "./dist/bindings/r2/src/index.d.ts",
      "import": "./dist/bindings/r2/src/index.js"
    },
    "./r2/node": {
      "types": "./dist/bindings/r2/src/providers/node/index.d.ts",
      "import": "./dist/bindings/r2/src/providers/node/index.js"
    }
  },
  "files": [
    "bindings/*/docs",
    "bindings/*/README.md",
    "dist",
    "docs",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "bench": "vitest bench",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redwoodjs/sourdough.git"
  },
  "homepage": "https://github.com/redwoodjs/sourdough#readme",
  "bugs": {
    "url": "https://github.com/redwoodjs/sourdough/issues"
  },
  "keywords": [
    "bindings",
    "cloudflare",
    "nodejs",
    "nub",
    "self-hosted"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "author": "Peter Pistorius",
  "license": "MIT",
  "dependencies": {
    "capnweb": "^0.4.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
